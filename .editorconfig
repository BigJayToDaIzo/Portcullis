root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.cs]
indent_size = 4

# Roslynator: RCS1194 "Implement exception constructors".
# Disabled — our domain exceptions deliberately require structured data
# (SecretId, Name, UserId+AuditAction). The canonical three-ctor pattern
# would allow constructing invalid exceptions with no payload.
dotnet_diagnostic.RCS1194.severity = none

[*.{json,yml,yaml,http,csproj,props,targets}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2
